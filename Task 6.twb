      <table>
        <view>
          <datasources>
            <datasource caption='job descriptions (job descriptions)' name='federated.1i1syuw1vpklc81fcu30t1yevhni' />
          </datasources>
          <datasource-dependencies datasource='federated.1i1syuw1vpklc81fcu30t1yevhni'>
            <column caption='Country Filter' datatype='boolean' name='[Calculation_2762845402550272]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='NOT STARTSWITH([Country], &quot;A&quot;)&#13;&#10;AND NOT STARTSWITH([Country], &quot;B&quot;)&#13;&#10;AND NOT STARTSWITH([Country], &quot;C&quot;)&#13;&#10;AND NOT STARTSWITH([Country], &quot;D&quot;)' />
            </column>
            <column caption='Job Title Filter' datatype='boolean' name='[Calculation_2762845402697729]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEN([Job Title]) &lt; 10&#13;&#10;AND NOT CONTAINS([Job Title], &quot; &quot;)' />
            </column>
            <column caption='Min Salary' datatype='integer' name='[Calculation_2762845403140098]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT(REPLACE(REPLACE(SPLIT([Salary Range], &quot;-&quot;, 1), &quot;$&quot;, &quot;&quot;), &quot;k&quot;, &quot;&quot;)) * 1000' />
            </column>
            <column caption='Max Salary' datatype='integer' name='[Calculation_2762845403242499]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT(REPLACE(REPLACE(SPLIT([Salary Range], &quot;-&quot;, 2), &quot;$&quot;, &quot;&quot;), &quot;k&quot;, &quot;&quot;)) * 1000' />
            </column>
            <column caption='Salary Midpoint' datatype='real' name='[Calculation_2762845403340804]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Calculation_2762845403140098] + [Calculation_2762845403242499]) / 2' />
            </column>
            <column caption='Even Experience' datatype='boolean' name='[Calculation_2762845403668485]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='INT(SPLIT([Experience], &quot; &quot;, 1)) % 2 = 0' />
            </column>
            <column caption='Contact Filter' datatype='boolean' name='[Calculation_2762845404975110]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CONTAINS(LOWER([Contact Person]), &quot;e&quot;)' />
            </column>
            <column caption='Time Filter' datatype='boolean' name='[Calculation_2762845405102087]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, NOW()) &gt;= 15&#13;&#10;AND DATEPART(&apos;hour&apos;, NOW()) &lt;= 17' />
            </column>
            <column datatype='integer' name='[Company Size]' role='measure' type='quantitative' />
