      <aliases enabled='yes' />
      <column caption='County Filter' datatype='boolean' name='[Calculation_2981922404208640]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([Country],1) != &quot;A&quot;&#13;&#10;AND LEFT([Country],1) != &quot;B&quot;&#13;&#10;AND LEFT([Country],1) != &quot;C&quot;&#13;&#10;AND LEFT([Country],1) != &quot;D&quot;' />
      </column>
      <column caption='Job Title Filter' datatype='boolean' name='[Calculation_2981922404577281]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT CONTAINS([Job Title],&quot; &quot;)&#13;&#10;AND LEN([Job Title]) &lt; 10' />
      </column>
      <column caption='Min Salary' datatype='integer' name='[Calculation_2981922405191682]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(REPLACE(REPLACE(SPLIT([Salary Range],&apos;-&apos;,1),&apos;$&apos;,&apos;&apos;),&apos;k&apos;,&apos;&apos;)) * 1000' />
      </column>
      <column caption='Experience Number' datatype='integer' name='[Calculation_2981922405982212]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(SPLIT([Experience], &apos; to &apos;, 1))' />
      </column>
      <column caption='Even Experience' datatype='boolean' name='[Calculation_2981922406121477]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_2981922405982212] % 2 = 0' />
      </column>
      <column caption='Odd Month' datatype='boolean' name='[Calculation_2981922422788103]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATEPART(&apos;month&apos;,[Job Posting Date]) % 2 = 1' />
      </column>
      <column caption='Time Filter' datatype='boolean' name='[Calculation_2981922428575752]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, NOW()) &gt;= 15 &#13;&#10;AND DATEPART(&apos;hour&apos;, NOW()) &lt; 17' />
      </column>
      <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column datatype='integer' name='[Job Id]' role='dimension' type='ordinal' />
