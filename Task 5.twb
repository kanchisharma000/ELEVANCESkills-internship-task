          <datasource-dependencies datasource='federated.0vm2a5n0hvgqp017bexlu1p9p9hc'>
            <column caption='Company Valid' datatype='boolean' name='[Calculation_2872246784606208]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEN([Company]) &gt; 8' />
            </column>
            <column caption='Location Valid' datatype='boolean' name='[Calculation_2872246784741377]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='NOT ISNULL([location]) AND TRIM([location]) &lt;&gt; &quot;&quot;' />
            </column>
            <column caption='Min Experience' datatype='integer' name='[Calculation_2872246784884738]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT(SPLIT([Experience], &quot; &quot;, 1))' />
            </column>
            <column caption='Experience Valid' datatype='boolean' name='[Calculation_2872246785982467]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Calculation_2872246784884738] &gt; 2' />
            </column>
            <column caption='Time Filter' datatype='boolean' name='[Calculation_2872246787371012]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, NOW()) &gt;= 15 AND DATEPART(&apos;hour&apos;, NOW()) &lt; 17' />
            </column>
            <column caption='Min Salary' datatype='integer' name='[Calculation_2872246788534278]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT(REPLACE(REPLACE(SPLIT([Salary Range], &quot;-&quot;, 1), &quot;$&quot;, &quot;&quot;), &quot;k&quot;, &quot;&quot;)) * 1000' />
            </column>
            <column caption='Salary Valid' datatype='boolean' name='[Calculation_2872246788620295]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Calculation_2872246788534278] &gt; 10000' />
            </column>
