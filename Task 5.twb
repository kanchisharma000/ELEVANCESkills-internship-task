      <style>
        <style-rule element='mark'>
          <encoding attr='color' field='[none:Job Title:nk]' type='palette'>
            <map to='#499894'>
              <bucket>&quot;Art Director&quot;</bucket>
            </map>
            <map to='#499894'>
              <bucket>&quot;Database Administrator&quot;</bucket>
            </map>
            <map to='#499894'>
              <bucket>&quot;Front-End Developer&quot;</bucket>
