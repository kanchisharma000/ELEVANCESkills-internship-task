      <aliases enabled='yes' />
      <column caption='Ends With Vowel' datatype='boolean' name='[Calculation_2466251778408448]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='RIGHT(LOWER([Contact Person]),1) IN (&quot;a&quot;,&quot;e&quot;,&quot;i&quot;,&quot;o&quot;,&quot;u&quot;)' />
      </column>
      <column caption='Time Filter' datatype='boolean' name='[Calculation_2466251782758401]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, NOW()) &gt;= 15 &#13;&#10;AND DATEPART(&apos;hour&apos;, NOW()) &lt;= 17' />
      </column>
      <column caption='Country Filter' datatype='boolean' name='[Calculation_3621013892780032]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT (&#13;&#10;    [Country] IN (&#13;&#10;        &quot;China&quot;,&quot;India&quot;,&quot;Japan&quot;,&quot;South Korea&quot;,&quot;North Korea&quot;,&quot;Indonesia&quot;,&quot;Pakistan&quot;,&quot;Bangladesh&quot;,&#13;&#10;        &quot;Sri Lanka&quot;,&quot;Nepal&quot;,&quot;Bhutan&quot;,&quot;Myanmar&quot;,&quot;Thailand&quot;,&quot;Vietnam&quot;,&quot;Malaysia&quot;,&quot;Singapore&quot;,&#13;&#10;        &quot;Philippines&quot;,&quot;Cambodia&quot;,&quot;Laos&quot;,&quot;Mongolia&quot;,&quot;Afghanistan&quot;,&quot;Kazakhstan&quot;,&quot;Uzbekistan&quot;,&#13;&#10;        &quot;Turkmenistan&quot;,&quot;Kyrgyzstan&quot;,&quot;Tajikistan&quot;,&quot;Iran&quot;,&quot;Iraq&quot;,&quot;Saudi Arabia&quot;,&quot;UAE&quot;,&quot;Qatar&quot;,&#13;&#10;        &quot;Kuwait&quot;,&quot;Oman&quot;,&quot;Yemen&quot;,&quot;Jordan&quot;,&quot;Lebanon&quot;,&quot;Syria&quot;,&quot;Israel&quot;,&quot;Palestine&quot;,&quot;Turkey&quot;,&quot;Armenia&quot;,&#13;&#10;        &quot;Azerbaijan&quot;,&quot;Georgia&quot;,&quot;Maldives&quot;,&quot;Brunei&quot;,&quot;Timor-Leste&quot;&#13;&#10;    )&#13;&#10;)&#13;&#10;AND LEFT([Country],1) &lt;&gt; &quot;C&quot;' />
      </column>
