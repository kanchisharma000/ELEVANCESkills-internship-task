      <column caption='Time Filter' datatype='boolean' name='[Calculation_0926110535827456]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;,NOW()) &gt;= 15&#13;&#10;AND DATEPART(&apos;hour&apos;,NOW()) &lt;= 17' />
      </column>
      <column caption='Minimum Salary' datatype='integer' name='[Calculation_3533052368240641]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(&#13;&#10;REPLACE(&#13;&#10;REPLACE(&#13;&#10;LEFT([Salary Range], FIND([Salary Range], &quot;-&quot;)-1),&#13;&#10;&quot;$&quot;,&quot;&quot;),&#13;&#10;&quot;K&quot;,&quot;&quot;&#13;&#10;)&#13;&#10;) * 1000' />
      </column>
      <column caption='Asia Country Filter' datatype='boolean' name='[Calculation_3533052368822274]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([Country],1) &lt;&gt; &quot;I&quot;' />
      </column>
      <column caption='Vowel Check' datatype='boolean' name='[Calculation_3533052369641475]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='(LEN([Company]) - LEN(REPLACE(LOWER([Company]), &quot;a&quot;, &quot;&quot;))) +&#13;&#10;(LEN([Company]) - LEN(REPLACE(LOWER([Company]), &quot;e&quot;, &quot;&quot;))) +&#13;&#10;(LEN([Company]) - LEN(REPLACE(LOWER([Company]), &quot;i&quot;, &quot;&quot;))) +&#13;&#10;(LEN([Company]) - LEN(REPLACE(LOWER([Company]), &quot;o&quot;, &quot;&quot;))) +&#13;&#10;(LEN([Company]) - LEN(REPLACE(LOWER([Company]), &quot;u&quot;, &quot;&quot;))) &gt;= 2' />
      </column>
